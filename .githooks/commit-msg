#!/usr/bin/env bash
# .githooks/commit-msg — 强制 commit message 格式
# 格式: <type>(<scope>): <subject> 或 <type>: <subject>
# type: feat|fix|refactor|docs|test|chore|perf|ci|style|build|merge
# scope: api|device|gateway|bridge|app|web|deploy|db|docs|ota (可选)

MSG_FILE="$1"
MSG=$(cat "$MSG_FILE")

# 允许 merge / revert 消息
if echo "$MSG" | head -1 | grep -qE '^(Merge|Revert) '; then
    exit 0
fi

# 格式正则（scope 可选）
PATTERN='^(feat|fix|refactor|docs|test|chore|perf|ci|style|build|merge)(\([a-z-]+\))?: .{1,100}$'

if ! echo "$MSG" | head -1 | grep -qE "$PATTERN"; then
    echo "[HOOK] ERROR: Commit message does not match required format."
    echo ""
    echo "  Expected: <type>(<scope>): <subject>"
    echo "  Types:    feat|fix|refactor|docs|test|chore|perf|ci|style|build|merge"
    echo "  Scopes:   api|device|gateway|bridge|app|web|deploy|db|docs|ota (optional)"
    echo ""
    echo "  Examples:"
    echo "    feat(api): add user export endpoint"
    echo "    fix(device): correct MQTT reconnect logic"
    echo "    chore: update docker-compose ports"
    echo ""
    echo "  Your message: $MSG"
    exit 1
fi
