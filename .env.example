# ============================================================
# Inverter Monitor System - Environment Variables
# Copy this file to .env and fill in the actual values
# ============================================================

# ---------- Database ----------
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=inv_mqtt

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------- JWT ----------
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# ---------- API Gateway ----------
API_SERVER_URL=http://inv-api-server:8080
DEVICE_SERVER_URL=http://inv-device-server:8081

# ---------- MQTT Broker ----------
MQTT_BROKER=your-mqtt-broker.example.com
MQTT_PORT=8883
MQTT_CLIENT_ID=CSKJ-INV-SERVER-DEVICE
MQTT_USERNAME=CSKJ-INV-SERVER-DEVICE
MQTT_PASSWORD=CHANGE_ME_MQTT_PASSWORD

# ---------- Kafka ----------
KAFKA_BROKER=kafka:29092
KAFKA_TELEMETRY_TOPIC=inv-telemetry
KAFKA_ALARM_TOPIC=inv-alerts
KAFKA_COMMAND_TOPIC=inv-commands

# ---------- Email (optional) ----------
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

# ---------- SMS (optional) ----------
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
SMS_SIGN_NAME=
SMS_TEMPLATE=
