# Safe deployment template only. Real runtime credentials belong in the
# git-ignored deploy/.secrets/.env file and must be supplied with --env-file.
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_DB_PASSWORD
DB_NAME=inv_mqtt

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

JWT_SECRET=CHANGE_ME_AT_LEAST_32_RANDOM_CHARACTERS
INTERNAL_KEY=CHANGE_ME_INTERNAL_API_KEY

API_SERVER_URL=http://inv-api-server:8080
DEVICE_SERVER_URL=http://inv-device-server:8081

MQTT_BROKER=CHANGE_ME_MQTT_BROKER
MQTT_PORT=8883
MQTT_CLIENT_ID=CSKJ-INV-SERVER-DEVICE-LOCAL
MQTT_USERNAME=CHANGE_ME_MQTT_USERNAME
MQTT_PASSWORD=CHANGE_ME_MQTT_PASSWORD
MQTT_TLS_INSECURE=false
# When MQTT_TLS_INSECURE=true, set a real, non-zero 64-character SHA-256 pin.
MQTT_CERT_SHA256=

KAFKA_BROKER=kafka:9092
KAFKA_TELEMETRY_TOPIC=inv-telemetry
KAFKA_ALARM_TOPIC=inv-alarms
KAFKA_COMMAND_TOPIC=inv-commands

EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=

SMS_ACCESS_KEY=
SMS_SECRET_KEY=
SMS_SIGN_NAME=
SMS_TEMPLATE=

JPUSH_ENABLED=false
JPUSH_APP_KEY=
JPUSH_MASTER_SECRET=
JPUSH_TIMEOUT=10
JPUSH_DEDUP_TTL=120
