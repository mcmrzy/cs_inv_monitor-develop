# ============================================================
# cs_inv_monitor - Production Environment Variables
# Copy to .env.prod on the deployment host. Never commit the populated file.
# ============================================================

# ---------- Database ----------
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=inv_mqtt

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ---------- JWT ----------
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# ---------- Internal Communication ----------
INTERNAL_KEY=CHANGE_ME_INTERNAL_SECRET

# ---------- MQTT Broker (External EMQX) ----------
MQTT_BROKER=mqtt.example.com
MQTT_PORT=8883
MQTT_CLIENT_ID=CSKJ-INV-SERVER-DEVICE
MQTT_USERNAME=
MQTT_PASSWORD=CHANGE_ME_MQTT_PASSWORD
MQTT_TLS_SKIP_VERIFY=false

# ---------- Kafka (External) ----------
KAFKA_BROKER=kafka.example.com:9093
KAFKA_ENABLED=true
KAFKA_TELEMETRY_TOPIC=inv-telemetry
KAFKA_ALARM_TOPIC=inv-alerts
KAFKA_COMMAND_TOPIC=inv-commands

# ---------- Backend URLs ----------
API_SERVER_URL=http://inv-api-server:8080
DEVICE_SERVER_URL=http://inv-device-server:8081

# ---------- Email ----------
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_USER=
EMAIL_PASS=CHANGE_ME_EMAIL_AUTH_CODE
EMAIL_FROM=

# ---------- SMS (optional) ----------
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
SMS_SIGN_NAME=
SMS_TEMPLATE=

# ---------- JPush (极光推送) ----------
JPUSH_ENABLED=false
JPUSH_APP_KEY=
JPUSH_MASTER_SECRET=
JPUSH_TIMEOUT=10
JPUSH_DEDUP_TTL=120

# ---------- Deployment ----------
# Use an immutable image tag (normally the Git commit SHA), never "latest".
IMAGE_TAG=CHANGE_ME_GIT_COMMIT_SHA
