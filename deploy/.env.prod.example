# ============================================================
# cs_inv_monitor - Production Environment Variables
# Deploy to jiuxiaoyw.online
# ============================================================

# ---------- Database ----------
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DB_NAME=inv_mqtt

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ---------- JWT ----------
# Generate with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL

# ---------- Internal Communication ----------
INTERNAL_KEY=CHANGE_ME_INTERNAL_SECRET

# ---------- MQTT Broker (External EMQX) ----------
MQTT_BROKER=jiuxiaoyw.online
MQTT_PORT=1883
MQTT_CLIENT_ID=CSKJ-INV-SERVER-DEVICE
MQTT_USERNAME=CSKJ-INV-SERVER-DEVICE
MQTT_PASSWORD=CSKJINVSERVERDEVICE

# ---------- Kafka (External) ----------
KAFKA_BROKER=jiuxiaoyw.online:9092
KAFKA_ENABLED=true
KAFKA_TELEMETRY_TOPIC=inv-telemetry
KAFKA_ALARM_TOPIC=inv-alerts
KAFKA_COMMAND_TOPIC=inv-commands

# ---------- Backend URLs ----------
API_SERVER_URL=http://inv-api-server:8080
DEVICE_SERVER_URL=http://inv-device-server:8081

# ---------- Email ----------
EMAIL_HOST=smtp.qq.com
EMAIL_PORT=465
EMAIL_USER=sunhaoyu0221@qq.com
EMAIL_PASS=CHANGE_ME_EMAIL_AUTH_CODE
EMAIL_FROM=sunhaoyu0221@qq.com

# ---------- SMS (optional) ----------
SMS_ACCESS_KEY=
SMS_SECRET_KEY=
SMS_SIGN_NAME=
SMS_TEMPLATE=

# ---------- JPush (极光推送) ----------
JPUSH_ENABLED=true
JPUSH_APP_KEY=e89e8b711cd18f666705fe7f
JPUSH_MASTER_SECRET=b881a4cf3ba51cfef14b97c9
JPUSH_TIMEOUT=10
JPUSH_DEDUP_TTL=120
