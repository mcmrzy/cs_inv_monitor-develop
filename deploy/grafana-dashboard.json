{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": [],
      "title": "HTTP 服务",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "axisBorderShow": false },
          "mappings": [],
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "id": 2,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total[1m])) by (path)",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "title": "HTTP QPS",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "mappings": [],
          "unit": "ms"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "id": 3,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_ms_bucket[1m])) by (le, path))",
          "legendFormat": "p99 {{path}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_ms_bucket[1m])) by (le, path))",
          "legendFormat": "p95 {{path}}",
          "refId": "B"
        }
      ],
      "title": "HTTP 延迟",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          },
          "unit": "percent"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "id": 4,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"5..\"}[1m])) / sum(rate(http_requests_total[1m])) * 100",
          "legendFormat": "错误率",
          "refId": "A"
        }
      ],
      "title": "HTTP 错误率",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 5,
      "panels": [],
      "title": "设备与消息",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "mappings": [], "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 10 },
      "id": 6,
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [
        { "expr": "device_online_count", "refId": "A" }
      ],
      "title": "在线设备",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "mappings": [], "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 10 },
      "id": 7,
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [
        { "expr": "device_total_count - device_online_count", "refId": "A" }
      ],
      "title": "离线设备",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "mappings": [], "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 10 },
      "id": 8,
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [
        { "expr": "device_total_count", "refId": "A" }
      ],
      "title": "设备总数",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "mappings": [], "unit": "mps" }
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 10 },
      "id": 9,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        { "expr": "rate(mqtt_messages_total[5m])", "legendFormat": "MQTT msg rate", "refId": "A" }
      ],
      "title": "MQTT 消息速率",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 10,
      "panels": [],
      "title": "基础设施",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "mappings": [], "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 19 },
      "id": 11,
      "options": { "legend": { "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "pg_stat_database_numbackends{datname=\"inv_mqtt\"}",
          "legendFormat": "活跃连接",
          "refId": "A"
        }
      ],
      "title": "数据库连接池",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "mappings": [], "unit": "short" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 19 },
      "id": 12,
      "options": { "colorMode": "background", "graphMode": "area", "textMode": "auto" },
      "targets": [
        { "expr": "alerts_active_count", "refId": "A" }
      ],
      "title": "活跃告警数",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "mappings": [], "unit": "s" }
      },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 19 },
      "id": 13,
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "targets": [
        {
          "expr": "time() - process_start_time_seconds{job=\"inv-admin-backend\"}",
          "refId": "A"
        }
      ],
      "title": "服务运行时间",
      "type": "stat"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["inv-mqtt", "nestjs"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "prometheus" },
        "hide": 0,
        "label": "数据源",
        "name": "DS_PROMETHEUS",
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": { "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"] },
  "timezone": "browser",
  "title": "INV-MQTT 运维监控",
  "uid": "inv-mqtt-ops",
  "version": 1
}
