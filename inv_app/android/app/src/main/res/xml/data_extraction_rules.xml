<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ (API 31+) 数据提取规则 -->
<data-extraction-rules>
    <cloud-backup>
        <!-- 排除 SharedPreferences（含服务器配置和用户凭证） -->
        <exclude domain="sharedpref" path="FlutterSharedPreferences.xml"/>
        <exclude domain="sharedpref" path="app_config.xml"/>
    </cloud-backup>
    <device-transfer>
        <!-- 设备迁移同样排除敏感配置 -->
        <exclude domain="sharedpref" path="FlutterSharedPreferences.xml"/>
        <exclude domain="sharedpref" path="app_config.xml"/>
    </device-transfer>
</data-extraction-rules>
