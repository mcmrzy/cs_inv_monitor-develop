{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://contracts.csergy.example/events/authorization-cache-invalidated.v1.schema.json",
  "title": "Authorization Cache Invalidated V1",
  "description": "Published after an authorization fact changes and cached decisions must be discarded.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "event_id",
    "occurred_at",
    "root_tenant_id",
    "payload"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0"
    },
    "event_id": {
      "type": "string",
      "format": "uuid"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "root_tenant_id": {
      "type": "integer",
      "minimum": 1
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "authorization_version",
        "reason",
        "scope"
      ],
      "properties": {
        "authorization_version": {
          "type": "integer",
          "minimum": 1
        },
        "reason": {
          "type": "string",
          "enum": [
            "membership_changed",
            "role_changed",
            "scope_changed",
            "organization_changed",
            "asset_grant_changed",
            "session_revoked"
          ]
        },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "organization_id": {
              "type": "integer",
              "minimum": 1
            },
            "user_id": {
              "type": "integer",
              "minimum": 1
            },
            "membership_id": {
              "type": "integer",
              "minimum": 1
            },
            "resource_type": {
              "type": "string",
              "minLength": 1
            },
            "resource_id": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
