function go2SetupWizard() {
    window.open(baseUrl + '/web/maintain/setupWizard?serialNum=' + $('#inverterSearchInput').combogrid('getValue'));
}

function exportPdf(isNew) {
    if (typeof html2pdf !== 'undefined') {
        exportPdfConfirm(isNew)
    } else {
        $('#exportPdfButton').button('loading')
        $.getScript(`${baseUrl}/web/lib/html2pdf/html2pdf.bundle.min.js`, function () {
            $('#exportPdfButton').button('reset')
            exportPdfConfirm(isNew)
        });
    }
}

function exportPdfConfirm(isNew) {
    var inverterSn = $('#inverterSearchInput').combogrid('getValue');
    if (!inverterSn) {
        return;
    }

    //Scroll to top...
    $(window).scrollTop(0);

    //Expand all component...
    $('.setToggleHolder').each(function (index, element) {
        var $setToggleButton = $(element).find('.setToggleButton');
        var $targetId = $('#' + $setToggleButton.attr('id') + 'Target');
        if (!$targetId.is(':visible')) {
            $targetId.show();
            $setToggleButton.attr('src', resourceBaseUrl + '/web/img/maintain/ic_action_expand.png');
        }
    });

    //Hide all set buttons...
    $('#remoteSetContainer label.control-label').addClass('input-sm');
    $('#remoteSetContainer input.form-control').addClass('input-sm');
    $('#remoteSetContainer select.form-control').addClass('input-sm');
    $('#remoteSetContainer button').addClass('btn-sm').find(':not([onclick^="javascript: functionControl"]):not([onclick^="javascript: execActionNotice"])').hide();

    $('#pageContainer').css('margin-left', '0');
    $('#pageContainer').css('padding-top', '0');
    $('#pageContainer').css('width', '100%');

    if (!isNew) {
        var remoteSetContainer = document.getElementById('pageContainer');
    } else {
        checkScreenSize(true)
        $('.underline').each(function () {
            this.style.setProperty('width', '60%', 'important');
        });
        const targetTabValue = $("#remoteSetContainer span[targettab]")
        $.each(targetTabValue, (index, item) => {
            if (!$('.' + $(item).attr('targettab')).is(':visible')) {
                $('.' + $(item).attr('targettab')).show().addClass('tempOperateClass')
            }
        })
        const modeList = $('#WorkModeSelectionToggleButtonTarget .workingModeList li')
        $.each(modeList, (index, item) => {
            if ($(item).is(':visible') && !$(item).hasClass("activeModeBtn")) {
                var match = $(item).attr('onclick').replace('javascript: ', '').match(/openSetting\(.*?,\s*['"](.+?)['"]\)/);
                $('.' + match[1] + ':not(.chart *)').show().addClass('tempOperateClass')
            }
        })
        var remoteSetContainer = document.getElementById('remoteSetContainer');
    }
    setTimeout(() => {
        var opt = {filename: 'Remote_Set_' + inverterSn + '.pdf'};
        // New Promise-based usage:
        html2pdf().set(opt).from(remoteSetContainer).save();
    })


    //Recover
    setTimeout(function () {
        recoverPageContainer(isNew);
    }, 1000);
}

//Recover
function recoverPageContainer(isNew) {
    $('#pageContainer').css('margin-left', '210px');
    $('#pageContainer').css('padding-top', '80px');
    $('#pageContainer').css('width', 'calc(100% - 211px)');

    $('#remoteSetContainer label.control-label').removeClass('input-sm');
    $('#remoteSetContainer input.form-control').removeClass('input-sm');
    $('#remoteSetContainer select.form-control').removeClass('input-sm');
    $('#remoteSetContainer button').removeClass('btn-sm').find(':not([onclick^="javascript: functionControl"]):not([onclick^="javascript: execActionNotice"])').fadeIn();
    if (isNew) {
        $('.underline').css('width', 'auto');
        $('.tempOperateClass').hide()
        $('.remoteSetContainer').removeClass('tempOperateClass')
        checkScreenSize()
    }
}