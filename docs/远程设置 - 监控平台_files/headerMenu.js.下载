function initHeight() {
    var $box1 = $('#firstMenu')
    var $box2 = $('.ebase-frame-header-userTopBar')
    if(isOverlapping($box1, $box2)) {
        $('body>header') && $('body>header').css('height', '160px')
        $('.ebase-frame-header-userTopBar') && $('.ebase-frame-header-userTopBar').css('padding-top', '80px')
        $('.page-container') && $('.page-container').css('padding-top', '160px')
        $('#nav > div') && $('#nav > div').css('padding-top', '80px')
        $('#firstMenu .op-ebase-topMenu .menu-list .item .nameWrapper') && $('#firstMenu .op-ebase-topMenu .menu-list .item .nameWrapper').css('padding', '0px 30px 8px 30px')
        if(validNewline()) {
            $('#firstMenu .op-ebase-topMenu .menu-list .item .nameWrapper') && $('#firstMenu .op-ebase-topMenu .menu-list .item .nameWrapper').css('padding', '0px 10px 8px 10px')
        }
    } else {
        $('body>header') && $('body>header').css('height', '80px')
        $('.ebase-frame-header-userTopBar') && $('.ebase-frame-header-userTopBar').css('padding-top', '0px')
        $('.page-container') && $('.page-container').css('padding-top', '80px')
        $('#nav > div') && $('#nav > div').css('padding-top', '0px')
        $('#firstMenu .op-ebase-topMenu .menu-list .item .nameWrapper') && $('#firstMenu .op-ebase-topMenu .menu-list .item .nameWrapper').css('padding', '0px 30px 8px 30px')
    }
}

function isOverlapping($box1, $box2) {
    var box1 = $box1.offset();
    var box2 = $box2.offset();
    var width1 = $box1.outerWidth();
    var width2 = $box2.outerWidth();
    var height1 = $box1.outerHeight();
    var height2 = $box2.outerHeight();

    var left1 = box1.left;
    var top1 = box1.top;
    var right1 = left1 + width1;
    var bottom1 = top1 + height1;

    var left2 = box2.left;
    var top2 = box2.top;
    var right2 = left2 + width2;
    var bottom2 = top2 + height2;

    return !(right1 < left2 || left1 > right2 || bottom1 < top2 || top1 > bottom2);
}

function validNewline() {
    var $elements = $('#firstMenu .item')
    var previousTop = 0
    let isNewLine = false
    $elements.each(function(index, item) {
        var currentTop = $(this).offset().top;
        if (currentTop !== previousTop && index !== 0) {
            isNewLine = true
        }
        previousTop = currentTop;
    })
    return isNewLine
}

