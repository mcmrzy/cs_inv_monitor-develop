    $('#collectorPowerStationModal').text(plantName).data('plantId', plantId);
    $('#collectorPowerStationDialog').modal();
}

function favStationJumpFormatter(value, row) {
    return '<a href="javascript:execFavStationJump(' + row.plantId + ')">' + value + '</a>';
}

function execFavStationJump(plantId) {
    $.post(baseUrl + '/api/userVisit/update', { plantId: plantId }, function(response) {
        if(response.success) {
            window.location.href = baseUrl + '/web/monitor/inverter';
        }
    }, 'json');
}

function formatTimestampToSpecificDate(value){
    if (value) {
        let date = new Date(value);
        // 获取年、月、日
        let year = date.getFullYear();
        let month = ('0' + (date.getMonth() + 1)).slice(-2); 	// 月份从0开始，因此要加1
        let day = ('0' + date.getDate()).slice(-2); 			// 获取日，并确保为两位数

        // 拼接成指定格式的字符串
        let formattedDate = year + '-' + month + '-' + day;

        return formattedDate;
    }
}

function showTabelDialog() {
    // 显示弹窗
    $('#tabelDialog').modal().on('shown.bs.modal', function () {
        let columns = []
        columns = [{ field:'name', title:'Station name', width: '18%', formatter: favStationJumpFormatter }]
        if(isAdmin || isMaintain || isOwnerLevel) {
            columns = columns.concat([{field:'installerAccount',title:'Installer', width: '10%'},
                {field:'endUserAccount',title:'EndUser', width: '10%'}])
        }
        columns = columns.concat([{field:'country',title:'Country', width: '10%'},
            {field:'timezone',title:'Timezone', width: '8%'},
            {field:'createDate',title:'Create date', width: '10%'},
            {field:'updateTime',title:'update Time', hidden: true, formatter: function(value){
                    if (value){
                        let date = new Date(value);
                        // 获取年、月、日
                        let year = date.getFullYear();
                        let month = ('0' + (date.getMonth() + 1)).slice(-2); // 月份从0开始，因此要加1
                        let day = ('0' + date.getDate()).slice(-2); // 获取日，并确保为两位数
                        let formattedDate = year + '-' + month + '-' + day;

                        return formattedDate;
                    }
                }
            },
            {field:'remarks',title:'Remarks', width: '22%'},
            {field:'plantId',title:'Plant id', hidden: true},
            {field:'action',title:'Action', width: '13%', formatter: function(value, row, index ){
                    let plantId = row.plantId
                    let name = row.name
                    let remarks = row.remarks
                    // return "<a class='' onclick='unstoredPowerStationA(" + plantId + ")'>cancel collection</a>"}},
                    return '<div class="actionHolder"><button button class="btn btn-default btn-xs" style="margin-right: 5px;" onclick="storagePowerStation(' + plantId + ', \'' + name.replace(/\'/g, '\\\'') + '\', \'' + remarks.replace(/\'/g, '\\\'') + '\');">Edit</button>' +
                        "<button button class='btn btn-default btn-xs' style='margin-right: 5px;' onclick='unstoredPowerStationA(" + plantId + ")'>Cancel</button></div>"}},
        ])
        // 弹窗显示完成后，加载数据到数据表格
        $('#collectorPowerStationTable').datagrid({
            url: baseUrl + '/api/userFav/getUserFavPlantRecordList?clientType=WEB',
            columns: [columns],
            pagination: false,
            fitColumns: true
        });
    });
}