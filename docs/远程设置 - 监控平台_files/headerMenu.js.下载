function goToCluster(clusterId, clusterPrefixUrl) {
    $.post(baseUrl + '/web/system/cluster/buildClusterKey', { serverClusterId: clusterId }, function(response) {
        if(response.success) {
            var sslClusterPrefixUrl = clusterPrefixUrl.replace('http://', 'https://');
            var href = window.location.href;
            var index = href.indexOf('/WManage');
            if(index > 0) {
                window.location.href = sslClusterPrefixUrl + '/WManage/web/login/clusterLoginForward?clusterLoginKey=' + response.clusterLoginKey + '&targetUrl=' + href.substring(index) + '&customCompany=' + customCompany;
            }
        }
    }, 'json');
}

var unstoredPowerStationA = function (plantId) {
