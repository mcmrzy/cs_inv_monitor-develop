function setDivFunctionParam(list, response) {
    $.each(list, function(index, item){
        let formParam = {}
        if(!item.isMultipleData) {
            formParam.firstIndex = 1
            formParam.lastIndex = 1
            formParam.param = (item.value || item.value ==0) ? item.param:item
        }else {
            formParam = item
        }
        for(let i = formParam.firstIndex; i<=formParam.lastIndex; i++) {
            let name = formParam.isMultipleData? formParam.param.replace(/\{(\w+)\}/g, i):formParam.param
            if(response.hasOwnProperty(name)) {
                $('div[functionParam="'+name+'"] button').each(function(inx, element) {
                    if($(element).hasClass('btn-success')) {
                        $(element).addClass('btn-default').removeClass('btn-success');
                    }
                });
                $('div[functionParam="'+name+'"] button[onclick*="' + ((item.value||item.value==0)? item.value : response[name]) + '"]').addClass('btn-success').removeClass('btn-default');
            }
        }
    })
}
