function fillSmartPortModeInput() {
    $('#smartPort1ModeInput option.invPort').remove();
    $('#smartPort1ModeInput option[value="0"]').text('Unused');
    $('#smartPort2ModeInput .acCouple').show();
    $('.smartPortBox2, .smartPortBox3, .smartPortBox4').show()
    $('.smartPortBox2 .smartPortLabel').show()
    $('.smartPortBox2 .smartLoadLabel').hide()
    $('.smartPortBox1 .smartPortLabel').show()
    $('.smartPortBox1 .smartPort1Label').hide()
    $('.smartPortBox1 .smartLoadLabel').hide()
    if(isMidMini()) {
        $('#smartPort1ModeInput').append('<option class="invPort" value="3">INV</option>');
        $('#smartPort2ModeInput .acCouple').hide();
        $('.smartPortBox3, .smartPortBox4').hide()
        $('.smartPortBox2 .smartPortLabel').hide()
        $('.smartPortBox2 .smartLoadLabel').show()
        $('.smartPortBox1 .smartPort1Label').show()
        $('.smartPortBox1 .smartPortLabel').hide()
        $('.smartPortBox1 .smartLoadLabel').hide()
    }
    if(isPowerHubLink()) {
        $('#smartPort1ModeInput option[value="0"]').text('Hybrid Inverter');
        $('.smartPortBox2, .smartPortBox3, .smartPortBox4').hide()
    }
}

function checkFuncNPEHolder() {
    if (isAdmin || isMaintain || isEG4Admin || isDevAccount) {
        $('.funcNPEHolder').show();
    } else if ((currentDeviceType == 8 || currentDeviceType == 10) && !isViewer) {
        $('.funcNPEHolder').show();
    } else {
        $('.funcNPEHolder').hide();
    }
}