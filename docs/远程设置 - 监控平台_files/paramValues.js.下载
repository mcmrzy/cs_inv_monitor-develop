var isWorkingModePage = (currentSetPageType && currentSetPageType.indexOf('workingMode2_') == 0);

function autoSelectSettingPage() {
	if(!isWorkingModePage) {
		if(currentDeviceType == 6 && currentSetPageType == 'remoteSetWeekly') {
			return true;
		}

		if(isSnaSeriesOrGeta() && currentSetPageType != 'remoteSetOffGrid') {
			window.location.href = baseUrl + '/web/maintain/remoteSetOffGrid';
		} else if(currentDeviceType == 5 && currentSetPageType != 'remoteSetLsp') {
			window.location.href = baseUrl + '/web/maintain/remoteSetLsp';
		} else if((currentDeviceType == 6 || (currentDeviceType == 7 && isAdmin) || isBess200K() || isTrip12K() || isMega24K() || currentDeviceType == 8 || currentDeviceType == 10) && !isHuayuAccount && currentSetPageType != 'remoteSet12K') {
			window.location.href = baseUrl + '/web/maintain/remoteSet12K';
		} else if(currentDeviceType == 7 && !isAdmin && currentSetPageType != 'remoteSetALLOne') {
			window.location.href = baseUrl + '/web/maintain/remoteSetAllInOne';
		} else if(currentDeviceType == 9 && currentSetPageType != 'remoteSetMidbox') {
			window.location.href = baseUrl + '/web/maintain/remoteSetMidbox';
		} else if(!isSnaSeriesOrGeta() && currentSetPageType == 'remoteSetOffGrid') {
			window.location.href = baseUrl + '/web/maintain/remoteSet';
		} else if(currentDeviceType != 5 && currentSetPageType == 'remoteSetLsp') {
			window.location.href = baseUrl + '/web/maintain/remoteSet';
		} else if(((currentDeviceType != 6 && !isTrip12K() && !isBess200K() && !(currentDeviceType == 7 && isAdmin) && !isMega24K() && currentDeviceType != 8 && currentDeviceType != 10) || isHuayuAccount) && currentSetPageType == 'remoteSet12K') {
			window.location.href = baseUrl + '/web/maintain/remoteSet';
		} else if(currentDeviceType != 7 && currentSetPageType == 'remoteSetALLOne') {
			window.location.href = baseUrl + '/web/maintain/remoteSet';
		} else if(currentDeviceType != 9 && currentSetPageType == 'remoteSetMidbox') {
			window.location.href = baseUrl + '/web/maintain/remoteSet';
		}
	} else {
		var settingPageMatch = false;
		if(isSnaSeriesOrGeta()) {
			if(currentSetPageType != 'workingMode2_OffGrid') {
				window.location.href = baseUrl + '/web/maintain/workingMode/sna';
			} else {
				settingPageMatch = true;
			}
		} else if(currentDeviceType == 6 || (currentDeviceType == 7 && isAdmin) || isBess200K() || isTrip12K() || isMega24K() || currentDeviceType == 8 || currentDeviceType == 10) {
			if(currentSetPageType != 'workingMode2_12K') {
				window.location.href = baseUrl + '/web/maintain/workingMode/12k';
			} else {
				settingPageMatch = true;
			}
		} else if(isMidboxNotEqb()) {
			if(currentSetPageType != 'workingMode2_Midbox') {
				window.location.href = baseUrl + '/web/maintain/workingMode/midbox';
			} else {
				settingPageMatch = true;
			}
		} else if(isHybird() || currentDeviceType == 2 || !currentModuleInverterSn) {
			if(currentSetPageType != 'workingMode2_Hybrid') {
				window.location.href = baseUrl + '/web/maintain/workingMode/hybrid';
			} else {
				settingPageMatch = true;
			}
		} else if(isEQB()) {
            if(currentSetPageType != 'workingMode2_Eqb') {
                window.location.href = baseUrl + '/web/maintain/workingMode/eqb';
            } else {
                settingPageMatch = true;
            }
        }

		if(!settingPageMatch) {
			window.location.href = baseUrl + '/web/maintain/remoteSet';
		}
	}
}

