async function refreshUserVisitRecordAndNotice(serialNum, plantId) {
    userVisitRecordPlantId = plantId;
    userVisitRecordSerialNum = serialNum;

    if(!isInit) {
        await new Promise((resolve) => {
            $.post(baseUrl + '/api/userVisit/update', {plantId: plantId, serialNum: serialNum}, function (response) {
                if (response.success) {
                    userVisitRecordPlantId = response.plantId;
                    resolve(true)
                    if (typeof (onDeviceChangedDone) == "function") {
                        onDeviceChangedDone(serialNum);
                    }
                }
            }, 'json');
        })
    } else {
        isInit = false
    }

    var needInverterImg = $('.hasInvertImg .inverterImg').length
    if (needInverterImg) {
        inverterImgSrc = getDeviceIcon()
    }

    if (!selectPlantId) {
        $('#favoriteBtn').hide()
    } else {
        $('#favoriteBtn').show()
    }
    if(currentLost) {
        $('.inverterImg').removeClass('inverterImgOnline')
    } else {
        $('.inverterImg').addClass('inverterImgOnline')
    }
    onDeviceChanged(serialNum);					//Custom method implements by page
}

function getDeviceIcon(device = null) {
    let inverterImgSrc = ''
    var selectDeviceType = currentDeviceType
    var selectSubDeviceType = currentSubDeviceType
    var selectPowerRating = currentPowerRating
    var selectCurrentPhase = currentPhase
    var selectMachineType = currentMachineType
    if(device) {
        selectDeviceType = device.deviceType
        selectSubDeviceType = device.subDeviceType
        selectPowerRating = device.powerRating
        selectCurrentPhase = device.phase
        selectMachineType = device.machineType
    }
    // let defaultValue = false
    if (hasCustomPlatformImg) {
        var monitorDirPath = '/web/platform/' + customPlatform + '/img/monitor/plant/deviceIcon/';
        var midboxDirPath = '/web/platform/' + customPlatform + '/img/monitor/midbox/';
    } else {
        var monitorDirPath = '/web/img/monitor/plant/deviceIcon/';
        var midboxDirPath = '/web/img/monitor/midbox/';
    }
    if(isPowerZone) {
        var monitorDirPath = '/web/platform/POWER_ZONE/img/monitor/plant/deviceIcon/';
    }
    var getaImagePath = monitorDirPath + ((platform == 'LUX_POWER' || hasCustomPlatformImg || isPowerZone) ? 'icon_geta.png' : 'icon_geta_mid.png');
