function checkHybridFirmware20240811(device) {
    if (device && device.deviceType == 0 && device.phase != 3) {		//Hybrid
        if(((device.standard == 'AAAA' || device.standard == 'aAAA') && device.slaveVersion >= 0x24 && device.fwVersion >= 0x20)
            || ((device.standard == 'AAAB' || device.standard == 'aAAB') && device.slaveVersion >= 0x1D && device.fwVersion >= 0x1A)) {
            return true;
        }
    }
    if (currentDeviceType == 0 && currentPhase != 3) {		//Hybrid
        if(((currentStandard == 'AAAA' || currentStandard == 'aAAA') && currentSlaveVersion >= 0x24 && currentFwVersion >= 0x20)
            || ((currentStandard == 'AAAB' || currentStandard == 'aAAB') && currentSlaveVersion >= 0x1D && currentFwVersion >= 0x1A)) {
            return true;
        }
    }
    return false;
}

