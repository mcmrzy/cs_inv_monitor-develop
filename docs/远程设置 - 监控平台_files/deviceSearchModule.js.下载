$(document).ready(function () {
    function refreshPlantComboAndChart() {
        firstPlantSearchSuccess = true;
        firstInverterSearchSuccess = true;
        $('#plantSearchInput').combogrid('setValue', '');
        $('#plantSearchInput').combogrid('grid').datagrid('load');
    }

    $('#selectPlantFirstCheckbox').change(function () {
        if ($('#selectPlantFirstCheckbox').is(':checked')) {
            $('#plantSearchHolder').fadeIn(refreshPlantComboAndChart);
        } else {
            $('#plantSearchHolder').fadeOut(refreshInverterComboAndChart);
        }
    });

    function refreshInverterComboAndChart() {
        firstInverterSearchSuccess = true;
        $('#inverterSearchInput').combogrid('setValue', '');
        $('#inverterSearchInput').combogrid('grid').datagrid('load');
    }

    function initInverterSearchInput() {
        $('#inverterSearchInput').combogrid({
            panelWidth: 530,
            url: baseUrl + '/web/config/inverter/list',
            idField: 'serialNum',
            textField: 'serialNum',
            mode: 'remote',
            delay: 1000,
            fitColumns: true,
            pagination: true,
            pageSize: 10,
            onBeforeLoad: function (param) {
                if ($('#selectPlantFirstCheckbox').is(':checked')) {
                    var plantSearchGridSelected = $('#plantSearchInput').combogrid('grid').datagrid('getSelected');
                    if (!plantSearchGridSelected) {
                        return false;
                    }
                    param.plantId = plantSearchGridSelected.id;
                }
                if($('#inverterSearchInput').combogrid('getValue') != userVisitRecordSerialNum) {
                    param.searchText = $('#inverterSearchInput').combogrid('getValue')
                }
                if(param.searchText && param.searchText.length <4) {
                    return false
                }
                param.targetSerialNum = userVisitRecordSerialNum;
            },
            onSelect: async function (index, row) {
                currentModuleInverterSn = row.serialNum;
                currentDatalogSn = row.datalogSn;
                currentProtocolVersion = row.protocolVersion;
                currentPhase = row.phase;
                currentDeviceType = row.deviceType;
                currentSubDeviceType = row.subDeviceType
                currentPowerRating = row.powerRating;
                currentDtc = row.dtc;
                currentVoltClass = row.voltClass;
                currentMachineType = row.machineType;
                currentMeterType = row.meterType;
                currentParallelEnabled = row.parallelEnabled;
                currentMasterOrSlaveNotOffGrid = (currentParallelEnabled ? row.masterOrSlave : -1);
                currentComposedPhaseNotOffGrid = (currentParallelEnabled ? row.composedPhase : -1);
                currentPvStringNumber = row.pvStringNumber;
                currentStandard = row.standard;
                currentSlaveVersion = row.slaveVersion;
                currentFwVersion = row.fwVersion;
                currentHardwareVersion = row.hardwareVersion
                currentBatteryType = row.batteryType;
                currentWithbatteryData = row.withbatteryData;
                currentBindTigoInfo = row.bindTigoInfo
                currentBindPhnixInfo = row.bindPhnixInfo
                currentBindChargePoint = row.bindChargePoint
                currentAllowExport2Grid = row.allowExport2Grid
                currentSetG98Already = row.setG98Already
                currentOdm = row.odm
                currentUsVersion = row.usVersion
                currentLost = row.lost
                var plantId = -1;
                if ($('#selectPlantFirstCheckbox').is(':checked')) {
                    var plantSearchGridSelected = $('#plantSearchInput').combogrid('grid').datagrid('getSelected');
                    if (plantSearchGridSelected) {
                        plantId = plantSearchGridSelected.id;
                    }
                }
                await refreshUserVisitRecordAndNotice(row.serialNum, plantId);
                // if(isEQB(row) || isOldSettingPage) {
                    window.location.reload()
                // }
            },
            onLoadSuccess: function (data) {
                isChangePage = false
                currentShowAutoParallelButton = data.showAutoParallelButton;
                if(currentShowAutoParallelButton && typeof hideAutoParallelButton == 'function') {
                    $('#autoParallelButton').fadeIn();
                    setTimeout(hideAutoParallelButton, 30000);
                }
                if (firstInverterSearchSuccess) {
                    firstInverterSearchSuccess = false;
                    $('#inverterSearchInput').combogrid('setValue', data.total > 0 ? data.rows[0].serialNum : '');

                    var backupModuleInverterSn = currentModuleInverterSn;

                    if (data.total > 0) {
                        currentModuleInverterSn = data.rows[0].serialNum;
                        currentDatalogSn = data.rows[0].datalogSn;
                        currentProtocolVersion = data.rows[0].protocolVersion;
                        currentPhase = data.rows[0].phase;
                        currentDeviceType = data.rows[0].deviceType;
                        currentSubDeviceType = data.rows[0].subDeviceType;
                        currentPowerRating = data.rows[0].powerRating;
                        currentDtc = data.rows[0].dtc;
                        currentVoltClass = data.rows[0].voltClass;
                        currentMachineType = data.rows[0].machineType;
                        currentMeterType = data.rows[0].meterType;
                        currentParallelEnabled = data.rows[0].parallelEnabled;
                        currentMasterOrSlaveNotOffGrid = (currentParallelEnabled ? data.rows[0].masterOrSlave : -1);
                        currentComposedPhaseNotOffGrid = (currentParallelEnabled ? data.rows[0].composedPhase : -1);
                        currentPvStringNumber = data.rows[0].pvStringNumber;
                        currentStandard = data.rows[0].standard;
                        currentSlaveVersion = data.rows[0].slaveVersion;
                        currentFwVersion = data.rows[0].fwVersion;
                        currentHardwareVersion = data.rows[0].hardwareVersion;
                        currentBatteryType = data.rows[0].batteryType;
                        currentWithbatteryData = data.rows[0].withbatteryData;
                        currentBindTigoInfo = data.rows[0].bindTigoInfo
                        currentBindPhnixInfo = data.rows[0].bindPhnixInfo
                        currentBindChargePoint = data.rows[0].bindChargePoint
                        currentAllowExport2Grid = data.rows[0].allowExport2Grid
                        currentSetG98Already = data.rows[0].setG98Already
                        currentOdm = data.rows[0].odm
                        currentUsVersion = data.rows[0].usVersion
                        currentLost = data.rows[0].lost
                    }

                    //Update visit record
                    var plantId = -1;
                    if ($('#selectPlantFirstCheckbox').is(':checked')) {
                        var plantSearchGridSelected = $('#plantSearchInput').combogrid('grid').datagrid('getSelected');
                        if (plantSearchGridSelected) {
                            plantId = plantSearchGridSelected.id;
                        }
                    }

                    if (!firstLoad || (data.rows.length > 0 && backupModuleInverterSn != data.rows[0].serialNum)) {
                        isInit = false;
                        refreshUserVisitRecordAndNotice(data.total > 0 ? data.rows[0].serialNum : '', plantId);
                    } else {
                        firstLoad = false
                    }
                }
            },
            columns: [[
                {field: 'serialNum', title: serialNumLabel, width: 80}
            ]]
        });
    }

    $('#plantSearchInput').combogrid({
        panelWidth: 530,
        url: plantListUrl,
        idField: 'id',
        textField: 'name',
        mode: 'remote',
        delay: 1000,
        fitColumns: true,
        pagination: true,
        pageSize: 10,
        onBeforeLoad: function (param) {
            plantSearchTextBeforeLoad = $('#plantSearchInput').combogrid('getText');
            param.searchText = plantSearchTextBeforeLoad;
            param.targetPlantId = userVisitRecordPlantId;
            param.forSelect = true
            param.sort = 'createDate';
            param.order = 'desc';
        },
        onSelect: function (index, row) {
            selectPlantId = row.id;
            selectPlantName = row.name;

            if (typeof (onPlantChanged) == "function") {
                onPlantChanged(selectPlantId, selectPlantName);
            }

            if (firstPlantSearchSuccess) {
                firstPlantSearchSuccess = false;
            } else {
                refreshInverterComboAndChart();
            }
        },
        onLoadSuccess: function (data) {
            $('#plantSearchInput').combogrid('setText', plantSearchTextBeforeLoad)
            if (firstPlantSearchSuccess) {
                if (data.total > 0) {
                    var plantSearchGrid = $('#plantSearchInput').combogrid('grid');
                    plantSearchGrid.datagrid('selectRecord', data.rows[0].id);
                } else {
                    firstPlantSearchSuccess = false;
                }

                initInverterSearchInput();
            }
        },
        columns: [[
            {
                field: 'name',
                title: plantNameLabel,
                formatter: plantSearchNameFormatter,
                width: 80
            }
        ]]
    });

})
