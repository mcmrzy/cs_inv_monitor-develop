$(document).ready(function() {
	$('.battSocHolder label.checkbox-inline input[type=checkbox]').change(function() {
		var $checkbox = $(this);
		if($checkbox.is(':checked')) {
			$checkbox.parents('.battSocHolder').find('input[type=text]').removeAttr('disabled');
		} else {
			$checkbox.parents('.battSocHolder').find('input[type=text]').attr('disabled', 'disabled');
		}
	});
});

function writeBattSocValue() {
	var params = new Array();
	
	var errorIndex = -1;
	var hasValue = false;
	
	$('.battSocHolder').each(function(index, element) {
		$element = $(element);
		if(errorIndex < 0 && $element.find('input[type=checkbox]').is(':checked')) {
			var value = $element.find('input[type=text]').val();
			if(!value || value.indexOf(',') >= 0 || !checkInt(value)) {
				if(errorIndex < 0) {
					errorIndex = index;
				}
			} else {
				hasValue = true;
				params.push(value);
			}
		} else {
			params.push('NaN');
		}
	});
	
	if(errorIndex >= 0) {
		alert('SOC of Module ' + errorIndex + ' can not be empty or invalid');
		return;
	}
	
	if(!hasValue) {
		alert(paramEmptyAlertText);
	}
	
	var inverterSn = $('#inverterSearchInput').combogrid('getValue');
	$.post(baseUrl + '/web/maintain/remoteSetBatt/writeMultiSocValue', {
			inverterSn: inverterSn,
			paramValueText: params.toString(),
			clientType: 'WEB',
			remoteSetType: 'NORMAL' }, function(response) {
		showPostWriteResult(response);
	}, 'json');
}

